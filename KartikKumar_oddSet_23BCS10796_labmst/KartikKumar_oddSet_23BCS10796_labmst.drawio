        <mxCell id="qcXrrN8o2vu8g5xNh5Mg-15" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="User Detail" vertex="1">
          <mxGeometry height="30" width="60" x="550" y="190" as="geometry" />
