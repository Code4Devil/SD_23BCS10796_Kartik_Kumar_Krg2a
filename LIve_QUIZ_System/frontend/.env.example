# REST base. Leave EMPTY in dev so the Vite proxy (see vite.config.js)
# forwards /api/** to the api-gateway — this avoids CORS. For production
# builds, set this to the absolute URL of your gateway.
VITE_API_BASE=
# SockJS endpoint. Same story — "/ws" is proxied by Vite in dev.
VITE_WS_URL=/ws
# Required when hitting the api-gateway (JWT filter). Mint with the script
# in the README; 24h expiry by default.
VITE_JWT_TOKEN=

